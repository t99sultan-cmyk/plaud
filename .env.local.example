# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (https://platform.openai.com/api-keys) — Whisper transcription
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com/settings/keys) — Claude summary + Q&A
ANTHROPIC_API_KEY=

# Inngest (https://app.inngest.com → Apps → "..." → Manage Signing Key)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App URL (used for callbacks, signed URLs)
APP_URL=http://localhost:3000
